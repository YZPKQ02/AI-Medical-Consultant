# App
HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# RAG
RAG_TOP_K=3
RAG_INDEX_PATH=storage/vector_index.json
CONSULTATION_STORE_PATH=storage/consultations.sqlite3
EMBEDDING_PROVIDER=qwen
QWEN_ENABLE_LOCAL=0

# Optional LLM orchestration
AGENT_LLM_ENABLED=0
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=
DEEPSEEK_API_KEY=
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1400
LLM_TIMEOUT_SECONDS=30

# Optional hospital recommendation through AMap MCP
HOSPITAL_RECOMMENDER_ENABLED=0
AMAP_MCP_URL=https://mcp.amap.com/mcp?key=<your-amap-key>
AMAP_WEB_SERVICE_KEY=
HOSPITAL_RECOMMENDER_LIMIT=5
HOSPITAL_RECOMMENDER_TIMEOUT_SECONDS=5
