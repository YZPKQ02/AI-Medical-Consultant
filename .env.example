# App
HOST=0.0.0.0
PORT=3000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# RAG
RAG_TOP_K=3
RAG_INDEX_PATH=storage/vector_index.json
CONSULTATION_STORE_PATH=storage/consultations.sqlite3
DATABASE_URL=
EMBEDDING_PROVIDER=qwen
QWEN_ENABLE_LOCAL=0
QWEN_LOCAL_FILES_ONLY=0
EMBEDDING_DIMENSION=1024
QWEN_TEXT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_QUERY_INSTRUCTION=Given a Chinese medical consultation query, retrieve clinically relevant passages for symptom assessment, risk triage, medication safety, and department recommendation.

# Optional LLM orchestration
AGENT_LLM_ENABLED=0
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=
DEEPSEEK_API_KEY=
LLM_TEMPERATURE=0.3
LLM_TOP_P=0.9
LLM_MAX_TOKENS=1400
LLM_TIMEOUT_SECONDS=30

# Optional hospital recommendation through AMap MCP
HOSPITAL_RECOMMENDER_ENABLED=0
AMAP_MCP_URL=https://mcp.amap.com/mcp?key=<your-amap-key>
AMAP_WEB_SERVICE_KEY=
HOSPITAL_RECOMMENDER_LIMIT=5
HOSPITAL_RECOMMENDER_TIMEOUT_SECONDS=5
